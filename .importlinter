[importlinter]
root_packages =
    services
    adapters
    lib
    domain
    models
include_external_packages = True

# Services must not import concrete adapters (protocols are OK).
[importlinter:contract:no-adapter-impl-in-services]
name = Services must not import concrete adapter implementations
type = forbidden
source_modules =
    services
forbidden_modules =
    adapters.romm.http
    adapters.romm.romm_api
    adapters.steam_config
    adapters.steamgriddb
    adapters.persistence
    adapters.retrodeck_paths
    adapters.retroarch_config
    adapters.retroarch_core_info

# Adapters must not import services
[importlinter:contract:no-services-in-adapters]
name = Adapters must not import services
type = forbidden
source_modules =
    adapters
forbidden_modules =
    services

# Utilities (lib/) must not import services, adapters, or domain
[importlinter:contract:utilities-independence]
name = Utilities must not import services, adapters, or domain
type = forbidden
source_modules =
    lib
forbidden_modules =
    services
    adapters
    domain

# Domain must not import services or adapters. lib is allowed: lib hosts
# layer-agnostic utilities (e.g. ISO timestamp parsing) shared by both
# domain and services.
[importlinter:contract:domain-independence]
name = Domain must not import services or adapters
type = forbidden
source_modules =
    domain
forbidden_modules =
    services
    adapters

# Models must not import services, adapters, domain, or lib
[importlinter:contract:models-independence]
name = Models must not import services, adapters, domain, or lib
type = forbidden
source_modules =
    models
forbidden_modules =
    services
    adapters
    domain
    lib

# Services must not import stdlib I/O or concurrency primitives directly.
# Real I/O belongs behind adapters; sleep, sync, and HTTP must come from
# Protocols (Sleeper, retry strategies, RommApiProtocol). This contract is a
# pure guardrail — none of the listed modules are imported by services
# today, and adding one is a Cosmic Python regression that should be
# caught at PR time.
#
# ``urllib.request`` is intentionally omitted: import-linter rejects
# subpackage names for forbidden external modules, and banning the
# whole ``urllib`` parent would also lock out ``urllib.parse`` /
# ``urllib.error`` which services legitimately need.
[importlinter:contract:no-stdlib-io-in-services]
name = Services must not import stdlib I/O or concurrency primitives
type = forbidden
source_modules =
    services
forbidden_modules =
    random
    subprocess
    threading
    requests

# Services must be independent of each other
[importlinter:contract:service-independence]
name = Services must not import other services
type = independence
modules =
    services.achievements
    services.artwork
    services.downloads
    services.firmware
    services.game_detail
    services.library
    services.metadata
    services.migration
    services.playtime
    services.rom_removal
    services.saves
    services.shortcut_removal
    services.steamgrid
