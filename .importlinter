[importlinter]
root_packages =
    services
    adapters
    lib
    domain
    models
include_external_packages = True

# Services must not import concrete adapters (Protocols are OK). Forbid the
# ``adapters`` root package wholesale, not a hand-enumerated denylist: services
# depend only on Protocols (defined in ``services/protocols/``), so they have
# zero legitimate adapter imports. A denylist rots — the old 8-module list had
# silently stopped covering ``adapters.repositories.*`` and ~15 other modules
# (#985). The completeness of the sibling ``service-independence`` list is
# guarded by ``scripts/check_service_independence_contract.py``.
[importlinter:contract:no-adapter-impl-in-services]
name = Services must not import concrete adapter implementations
type = forbidden
source_modules =
    services
forbidden_modules =
    adapters

# Adapters must not import services
[importlinter:contract:no-services-in-adapters]
name = Adapters must not import services
type = forbidden
source_modules =
    adapters
forbidden_modules =
    services

# Utilities (lib/) must not import services, adapters, or domain
[importlinter:contract:utilities-independence]
name = Utilities must not import services, adapters, or domain
type = forbidden
source_modules =
    lib
forbidden_modules =
    services
    adapters
    domain

# Domain is pure compute — no dependencies on any other internal layer.
# Services, adapters, lib, and models are all forbidden. Anything domain
# needs from "shared utilities" (e.g. ISO timestamp parsing) lives inside
# domain itself.
[importlinter:contract:domain-independence]
name = Domain must not import services, adapters, lib, or models
type = forbidden
source_modules =
    domain
forbidden_modules =
    services
    adapters
    lib
    models

# Domain is pure compute, stdlib + self only. ``_vendor`` hosts vendored
# third-party packages and is the only entry point for non-stdlib code
# into the codebase; banning it from domain enforces the CP doctrine
# that domain has no external runtime dependencies.
[importlinter:contract:domain-stdlib-only]
name = Domain must not import vendored third-party packages
type = forbidden
source_modules =
    domain
forbidden_modules =
    _vendor

# Models must not import services, adapters, domain, or lib
[importlinter:contract:models-independence]
name = Models must not import services, adapters, domain, or lib
type = forbidden
source_modules =
    models
forbidden_modules =
    services
    adapters
    domain
    lib

# Services must not import stdlib I/O, concurrency, or non-deterministic
# primitives directly. Real I/O belongs behind adapters; time, uuid, and
# async sleep come from Protocols (Clock, UuidGen, Sleeper) so services
# stay deterministic under test. ``time`` and ``uuid`` are banned now
# that every service has been migrated onto the injection seam — the
# UuidGen Protocol returns ``str`` so even ``services/protocols.py``
# does not need to import ``uuid``.
#
# ``urllib.request`` is intentionally omitted: import-linter rejects
# subpackage names for forbidden external modules, and banning the
# whole ``urllib`` parent would also lock out ``urllib.parse`` /
# ``urllib.error`` which services legitimately need.
#
# ``datetime.now()`` and ``asyncio.sleep()`` are call-level — see #303
# for a custom check that complements this import-level guardrail.
[importlinter:contract:no-stdlib-io-in-services]
name = Services must not import stdlib I/O or concurrency primitives
type = forbidden
source_modules =
    services
forbidden_modules =
    random
    subprocess
    threading
    requests
    time
    uuid

# Services must be independent of each other
[importlinter:contract:service-independence]
name = Services must not import other services
type = independence
modules =
    services.achievements
    services.active_core_resolver
    services.artwork
    services.connection
    services.cores
    services.downloads
    services.firmware
    services.game_detail
    services.launch_gate
    services.library
    services.metadata
    services.migration
    services.playtime
    services.rom_removal
    services.saves
    services.session_lifecycle
    services.settings
    services.shortcut_removal
    services.startup_healing
    services.steamgrid
