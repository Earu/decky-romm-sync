#!/bin/bash
# romm-launcher — Steam shortcut launcher for RomM Sync plugin
# Called by Steam with LaunchOptions as argument: romm:{rom_id}
# Resolves the ROM file path at launch time from the plugin's SQLite database
# (rom_installs table, opened read-only) and launches via RetroDECK. See
# docs/adr/0005-launcher-resolves-path-from-sqlite.md.

set -euo pipefail

# Parse rom ID from argument
if [[ -z "${1:-}" ]]; then
    echo "Usage: romm-launcher romm:<rom_id>" >&2
    exit 1
fi

ROM_ARG="$1"
if [[ ! "$ROM_ARG" =~ ^romm:([0-9]+)$ ]]; then
    echo "Invalid argument: $ROM_ARG (expected romm:<rom_id>)" >&2
    exit 1
fi

ROM_ID="${BASH_REMATCH[1]}"

# Resolve data directory (Decky runtime dir or well-known fallbacks)
DATA_DIR=""
for candidate in \
    "${DECKY_PLUGIN_RUNTIME_DIR:-}" \
    "$HOME/homebrew/data/decky-romm-sync" \
    "$HOME/.local/share/decky/data/decky-romm-sync"; do
    if [[ -d "$candidate" ]]; then
        DATA_DIR="$candidate"
        break
    fi
done

if [[ -z "$DATA_DIR" ]]; then
    echo "Data directory not found" >&2
    exit 1
fi

DB_FILE="$DATA_DIR/romm_sync.db"
if [[ ! -f "$DB_FILE" ]]; then
    echo "Database not found: $DB_FILE" >&2
    exit 1
fi

# Resolve ROM file path from the rom_installs table (read-only — WAL lets us
# query the last committed snapshot without blocking the plugin's writer).
export ROMM_DB_FILE="$DB_FILE"
export ROMM_ROM_ID="$ROM_ID"

ROM_PATH=$(python3 -c "
import os, sqlite3, sys
uri = 'file:' + os.environ['ROMM_DB_FILE'] + '?mode=ro'
conn = sqlite3.connect(uri, uri=True)
try:
    row = conn.execute(
        'SELECT file_path FROM rom_installs WHERE rom_id = ?',
        (int(os.environ['ROMM_ROM_ID']),),
    ).fetchone()
finally:
    conn.close()
if not row:
    sys.exit(1)
path = row[0] or ''
if not path:
    sys.exit(1)
print(path)
") || { echo "ROM $ROM_ID not found in database" >&2; exit 1; }

if [[ -z "$ROM_PATH" || ! -e "$ROM_PATH" ]]; then
    echo "ROM file not found: ${ROM_PATH:-<empty>}" >&2
    exit 1
fi

exec flatpak run net.retrodeck.retrodeck "$ROM_PATH"
